<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="br.com.aluguelequipamento.controller.PrimaryController"
            prefWidth="900" prefHeight="600"
            style="-fx-background-color: #f0f2f5;">

    <!-- TOPO -->
    <top>
        <VBox>
            <!-- Barra de menu -->
            <MenuBar style="-fx-background-color: #1a3a5c;">
                <Menu text="Arquivo" style="-fx-text-fill: white;">
                    <MenuItem text="Sair" onAction="#sair"/>
                </Menu>
                <Menu text="Cadastros">
                    <MenuItem text="Equipamentos" onAction="#abrirEquipamentos"/>
                    <MenuItem text="Clientes"     onAction="#abrirClientes"/>
                </Menu>
                <Menu text="Processos">
                    <MenuItem text="Reservas"    onAction="#abrirReservas"/>
                    <MenuItem text="Retiradas"   onAction="#abrirRetiradas"/>
                    <MenuItem text="Devoluções"  onAction="#abrirDevolucoes"/>
                    <MenuItem text="Manutenções" onAction="#abrirManutencoes"/>
                </Menu>
                <Menu text="Relatórios">
                    <MenuItem text="Relatório de Aluguel"  onAction="#abrirRelatorioAluguel"/>
                    <MenuItem text="Listagem de Reservas"  onAction="#abrirRelatorioReservas"/>
                    <MenuItem text="Manutenção"            onAction="#abrirRelatorioManutencao"/>
                </Menu>
            </MenuBar>

            <!-- Cabeçalho azul -->
            <HBox style="-fx-background-color: #2a5480; -fx-padding: 14 20;"
                  alignment="CENTER_LEFT" spacing="12">
                <Label text="🔧" style="-fx-font-size: 22;"/>
                <VBox>
                    <Label text="Sistema de Aluguel de Equipamentos"
                           style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Gerencie reservas, retiradas, devoluções e manutenções"
                           style="-fx-font-size: 11; -fx-text-fill: #aacce8;"/>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <!-- LATERAL ESQUERDA -->
    <left>
        <VBox style="-fx-background-color: white; -fx-border-color: #dde1e7;
                     -fx-border-width: 0 1 0 0;" prefWidth="200" spacing="2">
            <padding><Insets top="16" left="0" right="0" bottom="16"/></padding>

            <Label text="CADASTROS"
                   style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #8a9bb0;
                          -fx-padding: 0 0 4 16;"/>
            <Button text="  Equipamentos" maxWidth="Infinity"
                    onAction="#abrirEquipamentos"
                    style="-fx-background-color: transparent; -fx-alignment: CENTER_LEFT;
                           -fx-padding: 9 16; -fx-font-size: 13; -fx-cursor: hand;"/>
            <Button text="  Clientes" maxWidth="Infinity"
                    onAction="#abrirClientes"
                    style="-fx-background-color: transparent; -fx-alignment: CENTER_LEFT;
                           -fx-padding: 9 16; -fx-font-size: 13; -fx-cursor: hand;"/>

            <Separator style="-fx-padding: 8 0;"/>

            <Label text="PROCESSOS"
                   style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #8a9bb0;
                          -fx-padding: 4 0 4 16;"/>
            <Button text="  Reservas" maxWidth="Infinity"
                    onAction="#abrirReservas"
                    style="-fx-background-color: transparent; -fx-alignment: CENTER_LEFT;
                           -fx-padding: 9 16; -fx-font-size: 13; -fx-cursor: hand;"/>
            <Button text="  Retiradas" maxWidth="Infinity"
                    onAction="#abrirRetiradas"
                    style="-fx-background-color: transparent; -fx-alignment: CENTER_LEFT;
                           -fx-padding: 9 16; -fx-font-size: 13; -fx-cursor: hand;"/>
            <Button text="  Devoluções" maxWidth="Infinity"
                    onAction="#abrirDevolucoes"
                    style="-fx-background-color: transparent; -fx-alignment: CENTER_LEFT;
                           -fx-padding: 9 16; -fx-font-size: 13; -fx-cursor: hand;"/>
            <Button text="  Manutenções" maxWidth="Infinity"
                    onAction="#abrirManutencoes"
                    style="-fx-background-color: transparent; -fx-alignment: CENTER_LEFT;
                           -fx-padding: 9 16; -fx-font-size: 13; -fx-cursor: hand;"/>
        </VBox>
    </left>

    <!-- CENTRO — cards de resumo -->
    <center>
        <VBox spacing="20" style="-fx-padding: 30;">

            <Label text="Visão Geral"
                   style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1a3a5c;"/>

            <!-- Linha 1 de cards -->
            <HBox spacing="16">
                <!-- Card Equipamentos -->
                <VBox style="-fx-background-color: white; -fx-background-radius: 10;
                             -fx-border-color: #dde1e7; -fx-border-radius: 10;
                             -fx-padding: 18; -fx-cursor: hand;"
                      prefWidth="180" spacing="6" onMouseClicked="#abrirEquipamentos">
                    <Label text="🔧" style="-fx-font-size: 24;"/>
                    <Label text="Equipamentos"
                           style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1a3a5c;"/>
                    <Label fx:id="lblEquipamentos" text="Carregando..."
                           style="-fx-font-size: 12; -fx-text-fill: #6b7c93;"/>
                </VBox>

                <!-- Card Clientes -->
                <VBox style="-fx-background-color: white; -fx-background-radius: 10;
                             -fx-border-color: #dde1e7; -fx-border-radius: 10;
                             -fx-padding: 18; -fx-cursor: hand;"
                      prefWidth="180" spacing="6" onMouseClicked="#abrirClientes">
                    <Label text="👤" style="-fx-font-size: 24;"/>
                    <Label text="Clientes"
                           style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1a3a5c;"/>
                    <Label fx:id="lblClientes" text="Carregando..."
                           style="-fx-font-size: 12; -fx-text-fill: #6b7c93;"/>
                </VBox>

                <!-- Card Reservas -->
                <VBox style="-fx-background-color: white; -fx-background-radius: 10;
                             -fx-border-color: #dde1e7; -fx-border-radius: 10;
                             -fx-padding: 18; -fx-cursor: hand;"
                      prefWidth="180" spacing="6" onMouseClicked="#abrirReservas">
                    <Label text="📋" style="-fx-font-size: 24;"/>
                    <Label text="Reservas Ativas"
                           style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1a3a5c;"/>
                    <Label fx:id="lblReservas" text="Carregando..."
                           style="-fx-font-size: 12; -fx-text-fill: #6b7c93;"/>
                </VBox>
            </HBox>

            <!-- Linha 2 de cards -->
            <HBox spacing="16">
                <!-- Card Retiradas -->
                <VBox style="-fx-background-color: white; -fx-background-radius: 10;
                             -fx-border-color: #dde1e7; -fx-border-radius: 10;
                             -fx-padding: 18; -fx-cursor: hand;"
                      prefWidth="180" spacing="6" onMouseClicked="#abrirRetiradas">
                    <Label text="📦" style="-fx-font-size: 24;"/>
                    <Label text="Retiradas"
                           style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1a3a5c;"/>
                    <Label fx:id="lblRetiradas" text="Carregando..."
                           style="-fx-font-size: 12; -fx-text-fill: #6b7c93;"/>
                </VBox>

                <!-- Card Manutenções -->
                <VBox style="-fx-background-color: white; -fx-background-radius: 10;
                             -fx-border-color: #dde1e7; -fx-border-radius: 10;
                             -fx-padding: 18; -fx-cursor: hand;"
                      prefWidth="180" spacing="6" onMouseClicked="#abrirManutencoes">
                    <Label text="🛠️" style="-fx-font-size: 24;"/>
                    <Label text="Manutenções"
                           style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1a3a5c;"/>
                    <Label fx:id="lblManutencoes" text="Carregando..."
                           style="-fx-font-size: 12; -fx-text-fill: #6b7c93;"/>
                </VBox>

                <!-- Card Relatórios -->
                <VBox style="-fx-background-color: white; -fx-background-radius: 10;
                             -fx-border-color: #dde1e7; -fx-border-radius: 10;
                             -fx-padding: 18; -fx-cursor: hand;"
                      prefWidth="180" spacing="6">
                    <Label text="📊" style="-fx-font-size: 24;"/>
                    <Label text="Relatórios"
                           style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1a3a5c;"/>
                    <Label text="Aluguel · Reservas · Manutenção"
                           style="-fx-font-size: 12; -fx-text-fill: #6b7c93;"/>
                </VBox>
            </HBox>
        </VBox>
    </center>

    <!-- RODAPÉ -->
    <bottom>
        <HBox style="-fx-background-color: #1a3a5c; -fx-padding: 6 16;" spacing="16"
              alignment="CENTER_LEFT">
            <Label text="Sistema de Aluguel de Equipamentos v1.0"
                   style="-fx-text-fill: #aacce8; -fx-font-size: 11;"/>
            <Label text="|" style="-fx-text-fill: #4a6a8c;"/>
            <Label text="PostgreSQL" style="-fx-text-fill: #aacce8; -fx-font-size: 11;"/>
        </HBox>
    </bottom>
</BorderPane>